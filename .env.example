# Connexion à Neo4j (utilisée par backend/neo4j_client.py)
# - En local (backend lancé hors Docker, Neo4j exposé sur le port 7687) : bolt://localhost:7687
# - Avec docker-compose (backend et neo4j dans le même réseau) : bolt://neo4j:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=musicgraph123
